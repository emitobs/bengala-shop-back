generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER & AUTHENTICATION
// ============================================================

enum AuthProvider {
  LOCAL
  GOOGLE
  FACEBOOK
}

enum UserRole {
  CUSTOMER
  ADMIN
  WAREHOUSE
  SUPER_ADMIN
}

model User {
  id                   String       @id @default(cuid())
  email                String       @unique
  passwordHash         String?
  firstName            String
  lastName             String
  phone                String?
  avatarUrl            String?
  role                 UserRole     @default(CUSTOMER)
  authProvider         AuthProvider @default(LOCAL)
  authProviderId       String?
  emailVerified        Boolean      @default(false)
  emailVerifyToken     String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  addresses         Address[]
  orders            Order[]
  cart              Cart?
  reviews           Review[]
  favorites         Favorite[]
  refreshTokens     RefreshToken[]
  chatConversations ChatConversation[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
  @@map("refresh_tokens")
}

model Address {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String  @default("Casa")
  recipientName String
  street        String
  number        String
  apartment     String?
  city          String
  department    String
  postalCode    String
  phone         String?
  isDefault     Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]

  @@index([userId])
  @@map("addresses")
}

// ============================================================
// PRODUCT CATALOG
// ============================================================

model Category {
  id          String     @id @default(cuid())
  posId       String?    @unique // POS Familia.Id — for sync
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products ProductCategory[]

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Product {
  id               String   @id @default(cuid())
  posId            String?  @unique // POS Articulos.Id — for sync
  name             String
  slug             String   @unique
  description      String
  shortDescription String?
  sku              String   @unique
  basePrice        Decimal  @db.Decimal(10, 2)
  compareAtPrice   Decimal? @db.Decimal(10, 2)
  costPrice        Decimal? @db.Decimal(10, 2)
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  metaTitle        String?
  metaDescription  String?
  weight           Decimal? @db.Decimal(8, 3)
  dimensions       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  categories  ProductCategory[]
  images      ProductImage[]
  variants    ProductVariant[]
  reviews     Review[]
  favorites   Favorite[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  branchStock BranchStock[]

  @@index([slug])
  @@index([isActive, isFeatured])
  @@map("products")
}

model ProductCategory {
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

enum VariantType {
  SIZE
  COLOR
  MATERIAL
  STYLE
  OTHER
}

model ProductVariant {
  id                String      @id @default(cuid())
  productId         String
  product           Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name              String
  sku               String      @unique
  type              VariantType
  value             String
  priceAdjustment   Decimal     @default(0) @db.Decimal(10, 2)
  stock             Int         @default(0)
  lowStockThreshold Int         @default(5)
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

// ============================================================
// SHOPPING CART
// ============================================================

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity  Int             @default(1)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

// ============================================================
// ORDERS & PAYMENTS
// ============================================================

enum OrderStatus {
  PENDING
  PAYMENT_PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  MERCADOPAGO
  DLOCAL_GO
  SIMULATION
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELLED
  IN_PROCESS
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  userId            String
  user              User        @relation(fields: [userId], references: [id])
  addressId         String
  address           Address     @relation(fields: [addressId], references: [id])
  status            OrderStatus @default(PENDING)
  subtotal          Decimal     @db.Decimal(10, 2)
  shippingCost      Decimal     @db.Decimal(10, 2) @default(0)
  discount          Decimal     @db.Decimal(10, 2) @default(0)
  total             Decimal     @db.Decimal(10, 2)
  currency          String      @default("UYU")
  notes             String?
  shippingAddress   Json
  shippingMethod    String?
  trackingNumber    String?
  estimatedDelivery DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  items         OrderItem[]
  payment       Payment?
  statusHistory OrderStatusHistory[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  quantity    Int
  unitPrice   Decimal         @db.Decimal(10, 2)
  totalPrice  Decimal         @db.Decimal(10, 2)
  productName String
  productSku  String
  variantName String?

  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String          @unique
  order             Order           @relation(fields: [orderId], references: [id])
  provider          PaymentProvider
  status            PaymentStatus   @default(PENDING)
  externalId        String?
  externalPaymentId String?
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("UYU")
  paymentMethod     String?
  paymentDetail     Json?
  paidAt            DateTime?
  refundedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([externalId])
  @@index([externalPaymentId])
  @@index([status])
  @@map("payments")
}

model OrderStatusHistory {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  note       String?
  changedBy  String?
  createdAt  DateTime     @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

// ============================================================
// REVIEWS
// ============================================================

model Review {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int
  title      String?
  comment    String?
  isVerified Boolean @default(false)
  isApproved Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@map("reviews")
}

// ============================================================
// FAVORITES / WISHLIST
// ============================================================

model Favorite {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@map("favorites")
}

// ============================================================
// SHIPPING ZONES
// ============================================================

model ShippingZone {
  id            String   @id @default(cuid())
  name          String
  departments   String[]
  baseCost      Decimal  @db.Decimal(10, 2)
  freeAbove     Decimal? @db.Decimal(10, 2)
  estimatedDays Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("shipping_zones")
}

// ============================================================
// COUPONS
// ============================================================

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  description   String?
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  minPurchase   Decimal?     @db.Decimal(10, 2)
  maxDiscount   Decimal?     @db.Decimal(10, 2)
  usageLimit    Int?
  usageCount    Int          @default(0)
  isActive      Boolean      @default(true)
  startsAt      DateTime     @default(now())
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("coupons")
}

// ============================================================
// NEWSLETTER
// ============================================================

model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  isActive       Boolean   @default(true)
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  @@map("newsletter_subscribers")
}

// ============================================================
// BANNERS
// ============================================================

model Banner {
  id        String    @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String?
  position  String    @default("hero")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("banners")
}

// ============================================================
// STORE SETTINGS (singleton row)
// ============================================================

model StoreSettings {
  id             String   @id @default("default")
  hideOutOfStock Boolean  @default(false)

  // MercadoPago
  mpEnabled       Boolean  @default(false)
  mpAccessToken   String?
  mpPublicKey     String?
  mpWebhookSecret String?

  // dLocal Go
  dlEnabled       Boolean  @default(false)
  dlApiKey        String?
  dlSecretKey     String?
  dlApiUrl        String?

  updatedAt      DateTime @updatedAt

  @@map("store_settings")
}

// ============================================================
// CHAT / AI ASSISTANT
// ============================================================

model ChatConversation {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
  @@index([createdAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  products       Json?
  toolsUsed      String[]
  feedback       Int?
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

// ============================================================
// BRANCH SYNC (POS → Web)
// ============================================================

model Branch {
  id         String    @id @default(cuid())
  name       String
  code       String    @unique
  location   String
  apiKey     String    @unique
  isActive   Boolean   @default(true)
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  stockEntries BranchStock[]
  syncLogs     SyncLog[]

  @@map("branches")
}

model BranchStock {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([branchId, productId])
  @@index([productId])
  @@map("branch_stock")
}

model SyncLog {
  id        String   @id @default(cuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  type      String
  status    String
  itemCount Int      @default(0)
  duration  Int      @default(0)
  error     String?
  createdAt DateTime @default(now())

  @@index([branchId, createdAt])
  @@map("sync_logs")
}
